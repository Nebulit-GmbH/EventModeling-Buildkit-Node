{
  "name": "ralph-li",
  "version": "0.0.2",
  "description": "Real-time Claude agent that reacts to slice:changed events on an Eventmodelers board",
  "type": "module",
  "bin": {
    "ralph-li": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "eventmodelers",
    "slice-changed",
    "realtime-agent",
    "ralph-li"
  ],
  "author": "Martin Dilger",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
